# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# TypeScript, JavaScript, JSX, TSX
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# CSS, SCSS, LESS
[*.{css,scss,less}]
indent_style = space
indent_size = 2

# HTML
[*.html]
indent_style = space
indent_size = 2

# Package files
[{package.json,*.yml}]
indent_style = space
indent_size = 2

# Dotfiles
[.{babelrc,eslintrc,prettierrc}*]
indent_style = space
indent_size = 2

# Makefile
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
end_of_line = lf
indent_style = space
indent_size = 2

# Python (if used in future)
[*.py]
indent_style = space
indent_size = 4

# Ruby (if used in future)
[*.rb]
indent_style = space
indent_size = 2

# Go (if used in future)
[*.go]
indent_style = tab

# Rust (if used in future)
[*.rs]
indent_style = space
indent_size = 4

# Java (if used in future)
[*.java]
indent_style = space
indent_size = 4

# C/C++ (if used in future)
*.{c,cpp,h,hpp}
indent_style = space
indent_size = 4
